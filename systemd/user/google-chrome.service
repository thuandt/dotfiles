[Unit]
Description=Google Chrome Web Browser
PartOf=graphical-session.target
Requires=graphical-session.target

[Install]
WantedBy=graphical-session.target

[Service]
Type=exec
ExitType=cgroup
ExecStartPre=:/usr/bin/sleep 25
ExecStart=:/usr/bin/google-chrome
TimeoutStartSec=90s
Restart=no
TimeoutStopSec=5s
Slice=app.slice
